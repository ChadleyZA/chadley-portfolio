---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-text">
    Chadley De Rose <span>·</span> Web Developer <span>·</span> Cape Town, ZA
  </div>
  <div class="footer-text">Built with Astro <span>·</span> {year}</div>
</footer>

<style>
  footer {
    padding: 32px 48px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .footer-text {
    font-size: 12px;
    color: var(--muted);
  }

  .footer-text span {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      gap: 12px;
      text-align: center;
      padding: 24px;
    }
  }
</style>
