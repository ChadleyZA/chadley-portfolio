---
// src/components/Skills.astro

const skillGroups = [
  {
    icon: '🌐',
    title: 'Web Development',
    skills: [
      { label: 'HTML5', featured: true },
      { label: 'CSS3', featured: true },
      { label: 'JavaScript', featured: true },
      { label: 'Figma', featured: false },
      { label: 'WordPress', featured: true },
      { label: 'Website Maintenance', featured: false },
      { label: 'Frontend Dev', featured: false },
      { label: 'Backend Dev', featured: false },
      { label: 'Authentication Systems', featured: false },
    ],
  },
  {
    icon: '☁️',
    title: 'Cloud & Infrastructure',
    skills: [
      { label: 'Cloud Firewall Config', featured: true },
      { label: 'Virtual Machines', featured: true },
      { label: 'Backup & Storage', featured: false },
      { label: 'Cloud Service Platforms', featured: false },
      { label: 'Huawei HCIA', featured: true },
      { label: 'Cloud Security', featured: false },
    ],
  },
  {
    icon: '🔌',
    title: 'Networking',
    skills: [
      { label: 'TCP/IP', featured: true },
      { label: 'MPLS & SD-WAN', featured: true },
      { label: 'Network Troubleshooting', featured: false },
      { label: 'Cat5/Cat6 Cabling', featured: false },
      { label: 'Network Infrastructure', featured: false },
      { label: 'IP Networking', featured: false },
    ],
  },
  {
    icon: '📞',
    title: 'VoIP & Communication',
    skills: [
      { label: 'Hosted PBX Systems', featured: true },
      { label: 'VoIP Deployment', featured: true },
      { label: 'Contact Centre Platforms', featured: false },
      { label: 'VoIP Support', featured: false },
      { label: 'PBX Configuration', featured: false },
    ],
  },
  {
    icon: '🪟',
    title: 'Microsoft Technologies',
    skills: [
      { label: 'Microsoft 365', featured: true },
      { label: 'Identity Synchronization', featured: true },
      { label: 'User & Group Management', featured: false },
      { label: 'Windows 10/11 Admin', featured: false },
      { label: 'MS-102', featured: false },
    ],
  },
  {
    icon: '🛠️',
    title: 'IT Support',
    skills: [
      { label: 'Desktop Support', featured: true },
      { label: 'Hardware Troubleshooting', featured: true },
      { label: 'System Diagnostics', featured: false },
      { label: 'Software Support', featured: false },
      { label: 'Client IT Support', featured: false },
      { label: 'System Maintenance', featured: false },
    ],
