---

<section id="skills">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-num">02</span>
      <h2 class="section-title">Skills</h2>
      <div class="section-line"></div>
    </div>
    <div class="skills-grid fade-in">
      {
        skillGroups.map((group) => (
          <div class="skill-group">
            <span class="skill-group-icon">{group.icon}</span>
            <div class="skill-group-title">{group.title}</div>
            <div class="skill-tags">
              {group.skills.map((s) => (
                <span class={`tag${s.featured ? ' featured' : ''}`}>{s.label}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #skills {
    padding: 120px 0;
    background: var(--bg2);
    position: relative;
    z-index: 1;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .skill-group {
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 32px 28px;
    transition: all 0.25s;
  }

  .skill-group:hover {
    border-color: var(--border-hover);
    background: var(--bg4);
  }

  .skill-group:first-child  { border-radius: var(--radius) 0 0 0; }
  .skill-group:nth-child(3) { border-radius: 0 var(--radius) 0 0; }
  .skill-group:nth-child(4) { border-radius: 0 0 0 var(--radius); }
  .skill-group:last-child   { border-radius: 0 0 var(--radius) 0; }

  .skill-group-icon {
    font-size: 22px;
    margin-bottom: 16px;
    display: block;
  }

  .skill-group-title {
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 18px;
    color: var(--text);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (max-width: 768px) {
    .skills-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
