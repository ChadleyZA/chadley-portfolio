---
// src/components/Hero.astro
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-tag">Available for work</div>
    <h1 class="hero-name">
      Chadley<br />De <span class="accent">Rose.</span>
    </h1>
    <p class="hero-title">Web Developer & IT Specialist</p>
    <p class="hero-desc">
      Frontend & backend developer with 4+ years of hands-on experience building
      web solutions, deploying cloud infrastructure, and supporting business IT
      environments across Cape Town. Huawei HCIA certified.
    </p>
    <div class="hero-actions">
      <a href="#projects" class="btn-primary">View Projects →</a>
      <a href="#contact" class="btn-outline">Get in Touch</a>
    </div>
  </div>
  <div class="hero-scroll">Scroll to explore</div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 48px;
    width: 100%;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-dim);
    border: 1px solid rgba(212, 245, 78, 0.18);
    border-radius: 100px;
    padding: 5px 14px;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  .hero-name {
    font-family: var(--sans);
    font-size: clamp(52px, 8vw, 96px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .hero-name .accent {
    color: var(--accent);
  }

  .hero-title {
    font-family: var(--sans);
    font-size: clamp(20px, 3vw, 36px);
    font-weight: 400;
    color: var(--muted2);
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }

  .hero-desc {
    max-width: 560px;
    color: var(--muted2);
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 44px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-scroll::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--muted);
  }

  @media (max-width: 768px) {
    .hero-inner { padding: 0 24px; }
    .hero-scroll { left: 24px; }
  }
</style>
