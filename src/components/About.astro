---
// src/components/About.astro
---

<section id="about">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-num">01</span>
      <h2 class="section-title">About</h2>
      <div class="section-line"></div>
    </div>
    <div class="about-grid fade-in">
      <div class="about-text">
        <p>
          I'm a <strong>web developer and IT professional</strong> based in Cape
          Town with a background spanning frontend development, network
          infrastructure, and cloud systems. I bring a unique technical depth —
          I don't just build things that look good, I build things that
          <strong>work reliably</strong>.
        </p>
        <p>
          My journey started at <strong>LC Studio</strong> as an IT and Web
          Development intern, where I worked across frontend and backend systems,
          developing login interfaces and maintaining web platforms. I then spent
          over <strong>3 years at Innovo Networks</strong> as a PBX Technician,
          handling everything from cloud firewall configurations to website
          development support.
        </p>
        <p>
          I hold a <strong>Huawei HCIA Cloud Service Certification</strong> and
          multiple Microsoft certifications, and I'm actively transitioning into
          a full-time web development role.
        </p>
        <div class="about-ctas">
          <a href="mailto:chadleyderoseza@gmail.com" class="btn-primary">✉ Email Me</a>
          <a href="tel:+27794383711" class="btn-outline">☎ 079 438 3711</a>
        </div>
      </div>

      <div class="about-stats">
        <div class="stat-card">
          <div class="stat-num">4+</div>
          <div class="stat-label">Years of Experience</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">8+</div>
          <div class="stat-label">Certifications Earned</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">2+</div>
          <div class="stat-label">Companies Worked At</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">CPT</div>
          <div class="stat-label">Based in Cape Town</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #about {
    padding: 120px 0;
    position: relative;
    z-index: 1;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .about-text p {
    color: var(--muted2);
    margin-bottom: 20px;
    font-size: 14px;
    line-height: 1.85;
  }

  .about-text p strong {
    color: var(--text);
    font-weight: 500;
  }

  .about-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .about-ctas .btn-primary,
  .about-ctas .btn-outline {
    font-size: 12px;
    padding: 10px 20px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 28px 24px;
    transition: border-color 0.2s;
  }

  .stat-card:first-child  { border-radius: var(--radius) 0 0 0; }
  .stat-card:nth-child(2) { border-radius: 0 var(--radius) 0 0; }
  .stat-card:nth-child(3) { border-radius: 0 0 0 var(--radius); }
  .stat-card:last-child   { border-radius: 0 0 var(--radius) 0; }

  .stat-card:hover { border-color: var(--border-hover); }

  .stat-num {
    font-family: var(--sans);
    font-size: 36px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
